# --- Telegram ---
BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
ADMIN_TG_ID=0

# --- DB ---
POSTGRES_USER=hh
POSTGRES_PASSWORD=hh
POSTGRES_DB=hh
DATABASE_URL=postgresql+asyncpg://hh:hh@postgres:5432/hh

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Encryption (auto-generated on first run if empty) ---
COOKIES_ENC_KEY=
BACKUP_GPG_PASSPHRASE=

# --- AI (used from stage 7+) ---
AI_PROVIDER=openrouter
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_MODEL=openai/gpt-4o-mini

# --- Misc ---
DEFAULT_TZ=Europe/Moscow
DAILY_LIMIT_DEFAULT=200
DELAY_MIN_SEC=5
DELAY_MAX_SEC=25
LOG_LEVEL=INFO
